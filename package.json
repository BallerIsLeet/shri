{
  "name": "shri",
  "version": "0.1.0",
  "private": true,
  "description": "Shri — automated marketing content studio",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "concurrently -n web,worker -c blue,magenta \"pnpm --filter @shri/web dev\" \"pnpm --filter @shri/worker dev\"",
    "db:migrate": "pnpm --filter @shri/db prisma:migrate",
    "db:generate": "pnpm --filter @shri/db prisma:generate",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "build": "pnpm -r build",
    "build:railway": "pnpm --filter @shri/${SHRI_SERVICE:-web} build",
    "start": "pnpm --filter @shri/${SHRI_SERVICE:-web} start"
  },
  "pnpm": {
    "neverBuiltDependencies": ["@u4/opencv4nodejs"]
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.4.0"
  }
}
