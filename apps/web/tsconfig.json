{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shri/db": ["../../packages/db/src/index.ts"],
      "@shri/storage": ["../../packages/storage/src/index.ts"],
      "@shri/ai": ["../../packages/ai/src/index.ts"],
      "@shri/prompts-fs": ["../../packages/prompts-fs/src/index.ts"],
      "@shri/tools": ["../../packages/tools/index.ts"],
      "@shri/orchestrator": ["../../packages/orchestrator/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next", "dist"]
}
