# ---- AI gateway (shared defaults) ----
# Used by packages/ai/. Every namespace (chat, image, tts) falls back to these
# unless a per-method override is set below. See docs/18-ai-client.md.
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Per-namespace models (always set) ----
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# ---- Per-namespace API/base URL overrides (optional, only when splitting providers) ----
# OPENAI_CHAT_API_KEY=sk-or-v1-...
# OPENAI_CHAT_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_IMAGE_API_KEY=...
# OPENAI_IMAGE_BASE_URL=...
# OPENAI_TTS_API_KEY=...
# OPENAI_TTS_BASE_URL=...

# ---- BytePlus Seedance (video) ----
ARK_API_KEY=...
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com
ARK_VIDEO_MODEL=dreamina-seedance-2-0-260128

# ---- Cloudflare R2 ----
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=shri-assets
R2_PUBLIC_BASE_URL=https://assets.example.com   # public CDN host, used as Seedance input URLs

# ---- Infra ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shri
REDIS_URL=redis://localhost:6379
PROMPTS_DIR=./prompts-projects                  # mounted Railway volume in prod
BASIC_AUTH_USER=me
BASIC_AUTH_PASS=changeme
